# Cloudflare Pages — Redirects

# Root → English landing page (default)
/                   /en/                302

# Root-level files default to English edition (restores original behavior)
/login.html         /en/login.html      302
/app.html           /en/app.html        302
/reset.html         /en/reset.html      302
/success.html       /en/success.html    302

# GR edition — clean URLs for email marketing (funeralos.net/gr)
# 200 rewrites serve file content directly, bypassing the 302 rules above
/gr/login           /login.html         200
/gr/app             /app.html           200
/gr/reset           /reset.html         200
/gr/success         /success.html       200

# EN edition — clean URLs for email marketing (funeralos.net/en)
/en/login           /en/login.html      200
/en/app             /en/app.html        200
/en/reset           /en/reset.html      200
/en/success         /en/success.html    200
